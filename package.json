{
  "name": "runpane",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "api": "pnpm --filter @runpane/api dev",
    "symphony": "pnpm --filter @runpane/symphony start",
    "web": "pnpm --filter @runpane/web dev",
    "web:portless": "pnpm --filter @runpane/web dev:portless",
    "demo": "pnpm --filter @runpane/api demo",
    "build": "pnpm -r build",
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm api\" \"pnpm web:portless\"",
    "dev:local": "concurrently -n api,web -c blue,magenta \"pnpm api\" \"pnpm web\"",
    "portless:proxy": "portless proxy start --https --tld ai"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
